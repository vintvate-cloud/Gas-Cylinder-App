# Gas Cylinder App - Environment Variables
# Copy this file to .env and fill in the values

# API URL - Use localhost for development, production URL for release
# Development: http://10.0.2.2:5000 (Android emulator) or http://localhost:5000
# Production: https://gas-cylinder-app.onrender.com
EXPO_PUBLIC_API_URL=https://gas-cylinder-app.onrender.com

# RapidAPI Key for routing/directions
# Get your key from: https://rapidapi.com/
EXPO_PUBLIC_RAPID_API_KEY=d9dcd2ed79mshc1c06f9daa6331dp178d0cjsne0c1cf1ab3a4

# Google Maps API Key for map functionality
# Get your key from: https://console.cloud.google.com/
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
